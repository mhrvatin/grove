{
  "name": "grove",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsc --noEmit && tsc -p tsconfig.app.json --noEmit && vite build",
    "build:bundle": "vite build",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "description": "Project-agnostic worktree dev launcher + dashboard. Self-contained: no external project deps — point grove.config.jsonc at any repo. The dashboard is a React + Vite + TypeScript SPA (DASH-18); the launcher CLIs stay on node:*/Bun built-ins.",
  "bin": {
    "grove": "./src/cli/grove.ts"
  },
  "dependencies": {
    "commander": "15.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "lefthook": "2.1.4",
    "typescript": "5.9.3",
    "vite": "6.4.3"
  }
}
