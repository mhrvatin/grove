{
  "name": "grove",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.app.json --noEmit && vite build",
    "build:bundle": "vite build"
  },
  "description": "Project-agnostic worktree dev launcher + dashboard. Self-contained and extractable: no @facit or internal deps — lift this directory out to its own repo. The dashboard is a React + Vite + TypeScript SPA (DASH-18); the launcher CLIs stay on node:*/Bun built-ins.",
  "bin": {
    "grove-up": "./grove-up.ts",
    "grove-down": "./grove-down.ts",
    "grove-url": "./grove-url.ts",
    "grove": "./grove-dashboard.ts"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "typescript": "5.9.3",
    "vite": "6.4.2"
  }
}
